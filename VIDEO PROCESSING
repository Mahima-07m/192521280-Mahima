import cv2
cap = cv2.VideoCapture("video.mp4")  
if not cap.isOpened():
    print("Error: Cannot open video.")
    exit()
width = 640
height = 480
fps = cap.get(cv2.CAP_PROP_FPS)

fourcc = cv2.VideoWriter_fourcc(*'mp4v')
out = cv2.VideoWriter("output.mp4", fourcc, fps, (width, height), False)

cv2.namedWindow("Processed Video", cv2.WINDOW_NORMAL)
cv2.resizeWindow("Processed Video", width, height)

while True:
    ret, frame = cap.read()
    if not ret:
        break

    frame = cv2.resize(frame, (width, height))
    gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)

    cv2.imshow("Processed Video", gray)
    out.write(gray)
    
    if cv2.waitKey(25) & 0xFF == ord('q'):
        break
    
cap.release()
out.release()
cv2.destroyAllWindows()

print("Processed video saved as output.mp4")
